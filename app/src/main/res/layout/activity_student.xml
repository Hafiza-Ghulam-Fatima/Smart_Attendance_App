<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0A0F1E"
    tools:context=".StudentActivity">

    <!-- Top Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:background="#111827">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Student Portal"
            android:textColor="#EEF2FF"
            android:textStyle="bold"
            android:textSize="18sp"
            android:fontFamily="sans-serif-black"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🧑‍💻"
            android:textSize="22sp"/>
    </LinearLayout>

    <!-- Main Content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp">

        <!-- Scanner Icon Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="180dp"
            android:layout_height="180dp"
            android:layout_marginBottom="32dp"
            app:cardCornerRadius="90dp"
            app:cardBackgroundColor="#111827"
            app:cardElevation="20dp"
            xmlns:app="http://schemas.android.com/apk/res-auto">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📷"
                    android:textSize="52sp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="QR Scanner"
                    android:textColor="#6B7A99"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mark Your Attendance"
            android:textColor="#EEF2FF"
            android:textSize="24sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-black"
            android:layout_marginBottom="12dp"/>

        <!-- Description -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Point your camera at the teacher's QR code to instantly mark your attendance for this session."
            android:textColor="#6B7A99"
            android:textSize="14sp"
            android:gravity="center"
            android:lineSpacingMultiplier="1.5"
            android:layout_marginBottom="40dp"/>

        <!-- Scan Button -->
        <Button
            android:id="@+id/btnMarkAttendance"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="📷   Scan QR Code"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:backgroundTint="#4F8EF7"
            style="@style/Widget.MaterialComponents.Button"/>

        <!-- Status text (shown after scan) -->
        <TextView
            android:id="@+id/tvScanStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:padding="14dp"
            android:gravity="center"
            android:textSize="14sp"
            android:visibility="gone"
            android:background="@drawable/bg_badge"/>

    </LinearLayout>

</LinearLayout>