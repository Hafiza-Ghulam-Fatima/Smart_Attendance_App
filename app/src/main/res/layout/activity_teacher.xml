<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0A0F1E"
    tools:context=".TeacherActivity">

    <!-- Top Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:background="#111827">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Teacher Portal"
            android:textColor="#EEF2FF"
            android:textStyle="bold"
            android:textSize="18sp"
            android:fontFamily="sans-serif-black"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🎓"
            android:textSize="22sp"/>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Stats Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <!-- Sessions stat -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    app:cardCornerRadius="16dp"
                    app:cardBackgroundColor="#111827"
                    app:cardElevation="4dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="SESSIONS"
                            android:textColor="#6B7A99"
                            android:textSize="10sp"
                            android:letterSpacing="0.1"/>
                        <TextView
                            android:id="@+id/tvSessionCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="#4F8EF7"
                            android:textSize="28sp"
                            android:textStyle="bold"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Present stat -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    app:cardCornerRadius="16dp"
                    app:cardBackgroundColor="#111827"
                    app:cardElevation="4dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="PRESENT"
                            android:textColor="#6B7A99"
                            android:textSize="10sp"
                            android:letterSpacing="0.1"/>
                        <TextView
                            android:id="@+id/tvPresentCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="#22D3A0"
                            android:textSize="28sp"
                            android:textStyle="bold"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <!-- QR Code Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="20dp"
                app:cardBackgroundColor="#111827"
                app:cardElevation="6dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp"
                    android:gravity="center_horizontal">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="SESSION QR CODE"
                        android:textColor="#6B7A99"
                        android:textSize="11sp"
                        android:letterSpacing="0.08"
                        android:layout_marginBottom="16dp"/>

                    <!-- QR Code image with white card bg -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="200dp"
                        android:layout_height="200dp"
                        android:layout_marginBottom="16dp"
                        app:cardCornerRadius="12dp"
                        app:cardBackgroundColor="#FFFFFF"
                        app:cardElevation="4dp">
                        <ImageView
                            android:id="@+id/imgQrCode"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:padding="12dp"
                            android:contentDescription="QR Code"/>
                    </androidx.cardview.widget.CardView>

                    <!-- Session ID Badge -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_badge"
                        android:padding="12dp"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:layout_marginBottom="16dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Session ID: "
                            android:textColor="#6B7A99"
                            android:textSize="13sp"/>
                        <TextView
                            android:id="@+id/tvSessionId"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textColor="#4F8EF7"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:fontFamily="monospace"/>
                    </LinearLayout>

                    <!-- Generate Button -->
                    <Button
                        android:id="@+id/btnGenerateQr"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:text="⚡  Start New Session"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"
                        android:backgroundTint="#4F8EF7"
                        android:layout_marginBottom="10dp"
                        style="@style/Widget.MaterialComponents.Button"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Attendance List Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardBackgroundColor="#111827"
                app:cardElevation="6dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Header row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="ATTENDEES"
                            android:textColor="#6B7A99"
                            android:textSize="11sp"
                            android:letterSpacing="0.08"/>
                        <Button
                            android:id="@+id/btnRefreshList"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:text="🔄 Refresh"
                            android:textSize="12sp"
                            android:textColor="#4F8EF7"
                            android:backgroundTint="#1a2235"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>
                    </LinearLayout>

                    <!-- RecyclerView -->
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvAttendees"
                        android:layout_width="match_parent"
                        android:layout_height="320dp"
                        android:nestedScrollingEnabled="true"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <View android:layout_width="match_parent" android:layout_height="24dp"/>

        </LinearLayout>
    </ScrollView>

</LinearLayout>